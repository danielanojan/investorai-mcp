# InvestorAI MCP — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Data provider ──────────────────────────────────────────────────────────────
DATA_PROVIDER=yfinance          # yfinance (default, no key needed) | alpha_vantage | polygon
ALPHA_VANTAGE_KEY=              # required if DATA_PROVIDER=alpha_vantage
POLYGON_KEY=                    # required if DATA_PROVIDER=polygon

# ── LLM — BYOK ────────────────────────────────────────────────────────────────
# Used server-side for MCP tool calls and the /chat endpoint.
# Web chat reads the key from browser localStorage — not from here.
LLM_PROVIDER=anthropic          # anthropic | openai | groq
LLM_API_KEY=                    # sk-ant-... / sk-... / gsk_...
LLM_MODEL=claude-sonnet-4-20250514

# ── Langfuse (optional — LLM observability) ────────────────────────────────────
LANGFUSE_PUBLIC_KEY=            # pk-lf-...  (free tier at langfuse.com)
LANGFUSE_SECRET_KEY=            # sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── MCP transport ─────────────────────────────────────────────────────────────
MCP_TRANSPORT=http              # http (default) | stdio
MCP_HTTP_PORT=8000
MCP_HTTP_API_KEY=               # optional bearer token to protect the /mcp endpoint

# ── Feature flags ─────────────────────────────────────────────────────────────
AI_CHAT_ENABLED=true
SERVE_STALE_ONLY=false
VALIDATION_MODE=strict          # strict | warm_only

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MIN=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                 # text | json

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is the default — zero config, file created automatically on first run.
# Switch to PostgreSQL for production (Railway sets DATABASE_URL automatically).
DATABASE_URL=sqlite+aiosqlite:///./investorai.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/investorai

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
